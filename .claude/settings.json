{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm ci)",
      "Bash(npm test *)",
      "Bash(npx vite *)",
      "Bash(npx vitest *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx tsc *)",
      "Read",
      "Edit",
      "Write",
      "Bash(dotnet run *)",
      "Bash(dotnet build *)",
      "Bash(dotnet test *)",
      "Bash(dotnet watch *)",
      "Bash(dotnet ef *)",
      "Bash(dotnet add *)",
      "Bash(dotnet restore)",
      "Bash(dotnet format *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(rm -rf *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(appsettings.*.json)",
      "Read(**/secrets.json)",
      "Read(**/*.pfx)"
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "ASPNETCORE_ENVIRONMENT": "Development",
    "DOTNET_WATCH_RESTART_ON_RUDE_EDIT": "true"
  }
}
