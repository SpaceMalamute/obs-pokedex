{
	"compilerOptions": {
		"baseUrl": ".",
		"composite": true,
		"customConditions": ["@obs-pokedex/source"],
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"importHelpers": true,
		"isolatedModules": true,
		"lib": ["es2022"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmitOnError": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"paths": {
			"data-access": ["packages/pokemon/data-access/src/index.ts"],
			"feature": ["packages/pokemon/feature/src/index.ts"]
		},
		"skipLibCheck": true,
		"strict": true,
		"target": "es2022"
	}
}
