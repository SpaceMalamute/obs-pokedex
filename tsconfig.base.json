{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "customConditions": ["@obs-pokedex/source"],
    "declarationMap": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "shared-data-access": ["packages/shared/data-access/src/index.ts"]
    }
  }
}
